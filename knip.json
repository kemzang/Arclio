{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/main/index.ts",
    "src/preload/index.cts",
    "src/renderer/src/main.tsx",
    "electron.vite.config.ts",
    "scripts/**/*.ts"
  ],
  "project": [
    "src/**/*.{ts,tsx}",
    "scripts/**/*.ts",
    "tests/**/*.{ts,tsx}"
  ],
  "ignore": [
    "src/renderer/src/components/ui/**"
  ],
  "ignoreWorkspaces": [
    ".agents/**",
    ".claude/**"
  ],
  "ignoreExportsUsedInFile": {
    "interface": true,
    "type": true
  },
  "ignoreDependencies": [
    "@fontsource-variable/geist",
    "@fontsource/jetbrains-mono",
    "@fontsource/outfit",
    "@fontsource/poppins",
    "shadcn",
    "tw-animate-css",
    "tailwindcss",
    "@types/extract-zip",
    "gray-matter",
    "@iconify-json/logos",
    "@iconify-json/simple-icons",
    "@svgr/plugin-jsx"
  ],
  "ignoreUnresolved": [
    "~icons/.*"
  ]
}
