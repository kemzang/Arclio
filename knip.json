{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/main/index.ts",
    "src/preload/index.cts",
    "src/renderer/src/main.tsx",
    "electron.vite.config.ts",
    "scripts/**/*.ts"
  ],
  "project": [
    "src/**/*.{ts,tsx}",
    "scripts/**/*.ts",
    "tests/**/*.{ts,tsx}"
  ],
  "ignore": [
    "src/renderer/src/components/ui/**"
  ],
  "ignoreExportsUsedInFile": {
    "interface": true,
    "type": true
  },
  "ignoreDependencies": [
    "@fontsource/jetbrains-mono",
    "@fontsource/poppins",
    "@iconify-json/logos",
    "@iconify-json/simple-icons",
    "shadcn",
		"tw-animate-css",
		"tailwindcss",
		"@types/extract-zip",
		"@svgr/plugin-jsx"
	],
  "ignoreUnresolved": [
    "~icons/.*"
  ]
}
