---
import '../styles/global.css';
import { getLocale } from '../i18n/strings.ts';
import { buildHreflangLinks, buildOgLocaleAlt, buildLangDirsJson, buildLangPicker } from '../i18n/urls.ts';

interface Props {
  lang: string;
  title: string;
  description: string;
  canonical: string;
  ogType?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogImageWidth?: string;
  ogImageHeight?: string;
  ogImageAlt?: string;
  jsonLd?: string[];
  /** Blog post pages skip the locale redirect script */
  skipRedirect?: boolean;
  /** Which nav variant to render. 'landing' = section anchors, 'blog' = editorial nav. */
  nav?: 'landing' | 'blog';
}

const {
  lang,
  title,
  description,
  canonical,
  ogType = 'website',
  ogTitle,
  ogDescription,
  ogImage = 'https://arroxy.orionus.dev/assets/icon.png',
  ogImageWidth,
  ogImageHeight,
  ogImageAlt,
  jsonLd = [],
  skipRedirect = false,
  nav = 'landing',
} = Astro.props;

const RTL_LANGS = new Set(['ar', 'ur', 'ps', 'he', 'fa']);

const loc = getLocale(lang);
const s = loc.strings as Record<string, string>;
const ogLocale = loc.ogLocale;
const dir = RTL_LANGS.has(lang) ? 'rtl' : 'ltr';
const ogLocaleAlt = buildOgLocaleAlt(lang);
const hreflangLinks = buildHreflangLinks();
const langDirsJson = buildLangDirsJson();
const langPicker = buildLangPicker(lang);

const openpanelClientId = import.meta.env.LANDING_OPENPANEL_CLIENT_ID ?? '';

const homePath = loc.dir ? `/${loc.dir}/` : '/';
---

<!doctype html>
<html lang={lang} dir={dir} class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <Fragment set:html={`    ${hreflangLinks}`} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Arroxy" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={ogTitle ?? title} />
    <meta property="og:description" content={ogDescription ?? description} />
    <meta property="og:image" content={ogImage} />
    {ogImageWidth && <meta property="og:image:width" content={ogImageWidth} />}
    {ogImageHeight && <meta property="og:image:height" content={ogImageHeight} />}
    {ogImageAlt && <meta property="og:image:alt" content={ogImageAlt} />}
    <meta property="og:locale" content={ogLocale} />
    <Fragment set:html={`    ${ogLocaleAlt}`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle ?? title} />
    <meta name="twitter:description" content={ogDescription ?? description} />
    <meta name="twitter:image" content={ogImage} />
    {ogImageAlt && <meta name="twitter:image:alt" content={ogImageAlt} />}

    <meta name="theme-color" content="#0d1019" />
    <link rel="icon" href="/assets/icon.png" />
    <link rel="apple-touch-icon" href="/assets/icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

    {jsonLd.map((blob) => (
      <script type="application/ld+json" set:html={blob} />
    ))}

    {openpanelClientId && (
      <Fragment>
        <script set:html={`
      window.op = window.op || function(...args){(window.op.q=window.op.q||[]).push(args);};
      window.op('init', {
        clientId: '${openpanelClientId}',
        trackScreenViews: true,
        trackOutgoingLinks: true,
        trackAttributes: true,
      });`} />
        <script src="https://openpanel.dev/op1.js" defer async></script>
      </Fragment>
    )}
  </head>

  <body data-copied-label={s.copied_label}>
    {!skipRedirect && (
      <script set:html={`(function(){try{var p=location.pathname;if(p!=='/'&&p!=='/index.html'&&p!=='')return;var pa=new URLSearchParams(location.search);if(pa.has('lang'))return;if(navigator.webdriver)return;if(!navigator.languages&&!navigator.language)return;try{if(localStorage.getItem('langChosen'))return;}catch(_){}if(document.referrer){try{if(new URL(document.referrer).origin===location.origin)return;}catch(_){}}var S=${langDirsJson};var ls=(navigator.languages&&navigator.languages.length)?navigator.languages:[navigator.language||''];for(var i=0;i<ls.length;i++){var c=(ls[i]||'').toLowerCase().split('-')[0];if(S[c]){location.replace('/'+S[c]+'/');return;}}}catch(_){}})();`} />
    )}

    <nav>
      <div class="shell nav-inner">
        <a href={homePath} class="brand">
          <img src="/assets/icon.png" alt="Arroxy logo" />
          Arroxy
        </a>
        <div class="nav-links">
          {nav === 'blog' ? (
            <>
              <a href={homePath}>{s.nav_home}</a>
              <a href={`${homePath}blog/`} aria-current="page">{s.nav_blog}</a>
              <a href="https://github.com/antonio-orionus/Arroxy" target="_blank" rel="noopener">GitHub</a>
              <a class="nav-cta" href={`${homePath}#download`}>{s.nav_download}</a>
            </>
          ) : (
            <>
              <a href={`${homePath}#features`}>{s.nav_features}</a>
              <a href={`${homePath}#screenshots`}>{s.nav_screenshots}</a>
              <a href={`${homePath}#install`}>{s.nav_install}</a>
              <a href={`${homePath}blog/`}>{s.nav_blog}</a>
              <a href="https://github.com/antonio-orionus/Arroxy" target="_blank" rel="noopener">GitHub</a>
              <a class="nav-cta" href={`${homePath}#download`}>{s.nav_download}</a>
            </>
          )}
        </div>
      </div>
    </nav>

    <slot />

    <footer>
      <div class="shell">
        <div class="footer-langs">
          <span class="footer-langs-label">{s.footer_languages_label}</span>
          {langPicker.map(({ href, code, name, isCurrent }) => (
            <a
              href={href}
              hreflang={code}
              lang={code}
              aria-current={isCurrent ? 'page' : undefined}
            >{name}</a>
          ))}
        </div>
        <div class="footer-inner">
          <div>
            {s.footer_made_by}{' '}
            <a href="https://x.com/OrionusAI" target="_blank" rel="noopener">@OrionusAI</a>
          </div>
          <div class="footer-links">
            <a href="https://github.com/antonio-orionus/Arroxy" target="_blank" rel="noopener">{s.footer_github}</a>
            <a href="https://github.com/antonio-orionus/Arroxy/issues" target="_blank" rel="noopener">{s.footer_issues}</a>
            <a href="https://github.com/antonio-orionus/Arroxy/releases" target="_blank" rel="noopener">{s.footer_releases}</a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
