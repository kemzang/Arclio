---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLocale } from '../../i18n/strings.ts';
import { buildPostJsonLd } from '../../i18n/seo.ts';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const all = await getCollection('posts');
  return all.map((p) => ({ params: { slug: p.id } }));
}

const { slug } = Astro.params;
const lang = 'en';
const loc = getLocale(lang);
const s = loc.strings as Record<string, string>;

const all = await getCollection('posts');
const post = all.find((p) => p.id === slug);
if (!post) throw new Error(`Post not found: ${slug}`);

const { Content } = await render(post);

const canonical = `https://arroxy.orionus.dev/blog/${slug}/`;
const datePublished = post.data.datePublished.toISOString().slice(0, 10);
const dateModified = post.data.dateModified?.toISOString().slice(0, 10) ?? datePublished;

function humanDate(iso: string): string {
  return new Date(iso).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}

const jsonLd = [buildPostJsonLd({
  title: post.data.title,
  description: post.data.description,
  author: post.data.author,
  datePublished,
  dateModified,
  url: canonical,
  ogImage: post.data.ogImage,
})];
---

<BaseLayout
  lang={lang}
  title={post.data.title + ' — Arroxy Blog'}
  description={post.data.description}
  canonical={canonical}
  ogType="article"
  ogTitle={post.data.title}
  ogDescription={post.data.description}
  ogImage={post.data.ogImage}
  jsonLd={jsonLd}
  skipRedirect={true}
  nav="blog"
>
  <main class="shell pt-20 pb-[120px] max-w-[760px]">
    <a href="/blog/" class="text-[var(--text-dim)] text-[14px] no-underline inline-flex items-center gap-[6px] mb-10 transition-colors hover:text-[var(--brand-hover)]">
      {s.blog_back_to_index}
    </a>

    <div class="inline-block text-[12px] font-semibold uppercase tracking-[0.18em] text-[var(--brand-hover)] px-[14px] py-[6px] rounded-full bg-[hsl(220_100%_56%/0.1)] border border-[hsl(220_100%_56%/0.25)] mb-[22px]">{s.blog_eyebrow}</div>
    <h1 class="text-[clamp(1.8rem,3.6vw,2.8rem)] font-extrabold tracking-[-0.03em] mb-[18px]">{post.data.title}</h1>

    <div class="text-[14px] text-[var(--text-subtle)] mb-10">
      {s.blog_published_prefix} {humanDate(datePublished)}
      {dateModified !== datePublished && ` · ${s.blog_updated_prefix} ${humanDate(dateModified)}`}
      {' · '}{s.blog_by_author} <a href="https://x.com/OrionusAI" target="_blank" rel="noopener" class="text-inherit underline underline-offset-[3px]">{post.data.author}</a>
    </div>

    <article class="post-prose">
      <Content />
    </article>

    <div class="border-t border-[var(--border)] mt-16 pt-8">
      <a href="/blog/" class="text-[var(--text-dim)] text-[14px] no-underline hover:text-[var(--brand-hover)] transition-colors">
        {s.blog_back_to_index}
      </a>
    </div>
  </main>
</BaseLayout>
