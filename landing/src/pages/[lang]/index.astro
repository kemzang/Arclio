---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLocale, LOCALES } from '../../i18n/strings.ts';
import { buildJsonLd, buildFaqJsonLd, OG_IMAGE } from '../../i18n/seo.ts';
import { localeUrl } from '../../i18n/urls.ts';
import IconTemplates from '../../components/IconTemplates.astro';
import Hero from '../../components/Hero.astro';
import Features from '../../components/Features.astro';
import Screenshots from '../../components/Screenshots.astro';
import MidCta from '../../components/MidCta.astro';
import Privacy from '../../components/Privacy.astro';
import Faq from '../../components/Faq.astro';
import Install from '../../components/Install.astro';
import EndCta from '../../components/EndCta.astro';
import LandingScripts from '../../components/LandingScripts.astro';

export function getStaticPaths() {
  return LOCALES
    .filter((l) => l.code !== 'en')
    .map((l) => ({ params: { lang: l.code } }));
}

const { lang } = Astro.params;
const loc = getLocale(lang);
const s = loc.strings as Record<string, string>;

const canonical = localeUrl(loc);
const jsonLd = [buildJsonLd(loc), buildFaqJsonLd(loc)];
---

<BaseLayout
  lang={lang}
  title={s.title}
  description={s.description}
  canonical={canonical}
  ogTitle={s.og_title}
  ogDescription={s.og_description}
  ogImage={OG_IMAGE}
  ogImageWidth="1003"
  ogImageHeight="1123"
  ogImageAlt={s.og_image_alt}
  jsonLd={jsonLd}
>
  <IconTemplates />
  <Hero s={s} canonical={canonical} />
  <Features s={s} />
  <Screenshots s={s} />
  <MidCta s={s} />
  <Privacy s={s} />
  <Faq s={s} />
  <Install s={s} />
  <EndCta s={s} />
  <LandingScripts />
</BaseLayout>
