---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getLocale, LOCALES } from '../../../i18n/strings.ts';
import { localeUrl } from '../../../i18n/urls.ts';
import { getCollection } from 'astro:content';

export function getStaticPaths() {
  return LOCALES
    .filter((l) => l.code !== 'en')
    .map((l) => ({ params: { lang: l.code } }));
}

const { lang } = Astro.params;
const loc = getLocale(lang);
const s = loc.strings as Record<string, string>;
// Fall back to English for blog-chrome keys not yet translated
const en = getLocale('en');
const enS = en.strings as Record<string, string>;
const bs = (key: string) => s[key] ?? enS[key];

const canonical = `${localeUrl(loc)}blog/`;

const allPosts = await getCollection('posts');
const posts = allPosts
  .sort((a, b) => b.data.datePublished.getTime() - a.data.datePublished.getTime());

function humanDate(iso: string): string {
  return new Date(iso).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<BaseLayout
  lang={lang}
  title={bs('blog_index_h1') + ' — Arroxy'}
  description={bs('blog_index_tagline')}
  canonical={canonical}
  skipRedirect={true}
  nav="blog"
>
  <main class="shell pt-20 pb-[120px]">
    <div class="text-center mb-14">
      <div class="inline-block text-[12px] font-semibold uppercase tracking-[0.18em] text-[var(--brand-hover)] px-[14px] py-[6px] rounded-full bg-[hsl(220_100%_56%/0.1)] border border-[hsl(220_100%_56%/0.25)] mb-[22px]">{bs('blog_eyebrow')}</div>
      <h1 class="text-[clamp(2rem,4vw,3rem)] font-extrabold tracking-[-0.03em] mb-[14px]">{bs('blog_index_h1')}</h1>
      <p class="text-[var(--text-dim)] text-[1.1rem] mb-12">{bs('blog_index_tagline')}</p>
    </div>
    <div class="flex flex-col gap-[18px]">
      {posts.map((post) => {
        const slug = post.id;
        const published = post.data.datePublished.toISOString().slice(0, 10);
        const modified = post.data.dateModified?.toISOString().slice(0, 10);
        const dateStr = modified && modified !== published
          ? `${bs('blog_updated_prefix')} ${humanDate(modified)}`
          : `${bs('blog_published_prefix')} ${humanDate(published)}`;
        return (
          <a class="block px-7 py-6 bg-[var(--bg-card)] border border-[var(--border)] rounded-[14px] no-underline text-inherit transition-[transform,border-color,box-shadow] hover:-translate-y-0.5 hover:border-[var(--brand)] hover:shadow-[0_12px_30px_hsl(0_0%_0%/0.3)]" href={`/${lang}/blog/${slug}/`}>
            <div class="text-[13px] text-[var(--text-subtle)] mb-2">{dateStr} · {bs('blog_by_author')} {post.data.author}</div>
            <h2 class="text-[1.35rem] font-bold tracking-[-0.02em] mb-2 text-[var(--text)]">{post.data.title}</h2>
            <p class="text-[var(--text-dim)] text-[15px] leading-[1.55]">{post.data.description}</p>
            <span class="inline-block mt-[10px] text-[14px] font-semibold text-[var(--brand-hover)]">{bs('blog_read_more')}</span>
          </a>
        );
      })}
    </div>
  </main>
</BaseLayout>
