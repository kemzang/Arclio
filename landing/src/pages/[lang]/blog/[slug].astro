---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getLocale, LOCALES } from '../../../i18n/strings.ts';
import { localeUrl } from '../../../i18n/urls.ts';
import { buildPostJsonLd } from '../../../i18n/seo.ts';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const all = await getCollection('posts');
  return LOCALES
    .filter((l) => l.code !== 'en')
    .flatMap((l) => all.map((p) => ({ params: { lang: l.code, slug: p.id } })));
}

const { lang, slug } = Astro.params;
const loc = getLocale(lang);
const s = loc.strings as Record<string, string>;
const en = getLocale('en');
const enS = en.strings as Record<string, string>;
const bs = (key: string) => s[key] ?? enS[key];

const all = await getCollection('posts');
// Try localized version first, fall back to English canonical
const localized = all.find((p) => p.id === `${slug}.${lang}`);
const canonical_post = all.find((p) => p.id === slug);
const post = localized ?? canonical_post;
if (!post) throw new Error(`Post not found: ${slug}`);

const isFallback = !localized && lang !== 'en';
const { Content } = await render(post);

const canonical = `${localeUrl(loc)}blog/${slug}/`;
const datePublished = post.data.datePublished.toISOString().slice(0, 10);
const dateModified = post.data.dateModified?.toISOString().slice(0, 10) ?? datePublished;

function humanDate(iso: string): string {
  return new Date(iso).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}

const jsonLd = [buildPostJsonLd({
  title: post.data.title,
  description: post.data.description,
  author: post.data.author,
  datePublished,
  dateModified,
  url: canonical,
  ogImage: post.data.ogImage,
})];
---

<BaseLayout
  lang={lang}
  title={post.data.title + ' — Arroxy Blog'}
  description={post.data.description}
  canonical={canonical}
  ogType="article"
  ogTitle={post.data.title}
  ogDescription={post.data.description}
  ogImage={post.data.ogImage}
  jsonLd={jsonLd}
  skipRedirect={true}
  nav="blog"
>
  <main class="shell pt-20 pb-[120px] max-w-[760px]">
    <a href={`/${lang}/blog/`} class="text-[var(--text-dim)] text-[14px] no-underline inline-flex items-center gap-[6px] mb-10 transition-colors hover:text-[var(--brand-hover)]">
      {bs('blog_back_to_index')}
    </a>

    {isFallback && (
      <div class="bg-[var(--bg-card)] border border-[var(--border)] rounded-[10px] px-4 py-3 mb-7 text-[14px] text-[var(--text-dim)]">
        {bs('blog_lang_note')}
      </div>
    )}

    <div class="inline-block text-[12px] font-semibold uppercase tracking-[0.18em] text-[var(--brand-hover)] px-[14px] py-[6px] rounded-full bg-[hsl(220_100%_56%/0.1)] border border-[hsl(220_100%_56%/0.25)] mb-[22px]">{bs('blog_eyebrow')}</div>
    <h1 class="text-[clamp(1.8rem,3.6vw,2.8rem)] font-extrabold tracking-[-0.03em] mb-[18px]">{post.data.title}</h1>

    <div class="text-[14px] text-[var(--text-subtle)] mb-10">
      {bs('blog_published_prefix')} {humanDate(datePublished)}
      {dateModified !== datePublished && ` · ${bs('blog_updated_prefix')} ${humanDate(dateModified)}`}
      {' · '}{bs('blog_by_author')} <a href="https://x.com/OrionusAI" target="_blank" rel="noopener" class="text-inherit underline underline-offset-[3px]">{post.data.author}</a>
    </div>

    <article class="post-prose">
      <Content />
    </article>

    <div class="border-t border-[var(--border)] mt-16 pt-8">
      <a href={`/${lang}/blog/`} class="text-[var(--text-dim)] text-[14px] no-underline hover:text-[var(--brand-hover)] transition-colors">
        {bs('blog_back_to_index')}
      </a>
    </div>
  </main>
</BaseLayout>
