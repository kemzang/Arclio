---
import { Icon } from 'astro-icon/components';
import { InstallerTabs } from './InstallerTabs.tsx';
interface Props {
  s: Record<string, string>;
  canonical: string;
}
const { s, canonical } = Astro.props;
---
<header class="hero">
  <div class="shell hero-grid">
    <div class="hero-text">
      <div class="hero-eyebrow">{s.hero_eyebrow}</div>
      <div class="brandmark">Arroxy</div>
      <h1>{s.hero_h1_a}<br /><span class="grad">{s.hero_h1_b}</span></h1>
      <p class="tagline">{s.hero_tagline}</p>
      <div class="pill-row">
        <span class="pill ok">{s.pill_no_account}</span>
        <span class="pill ok">{s.pill_no_tracking}</span>
        <span class="pill ok">{s.pill_open_source}</span>
      </div>

      <div id="mobile-notice" style="display:none">
        <p class="mobile-notice-text">{s.mobile_notice}</p>
        <p class="mobile-notice-sub">{s.mobile_notice_sub}</p>
        <button class="btn btn-primary" id="mobile-copy-btn" data-copy-url={canonical} data-track="mobile-copy-link">
          <Icon name="lucide:link" width={18} height={18} aria-hidden="true" />
          {s.mobile_copy_link}
        </button>
      </div>

      <div class="cta-row scroll-mt-16" id="download">
        <div
          id="download-cta"
          aria-live="polite"
          data-label-win-installer={s.cta_download_windows}
          data-label-win-portable={s.cta_download_windows_portable}
          data-label-mac-arm={s.cta_download_mac_arm}
          data-label-mac-intel={s.cta_download_mac_intel}
          data-label-linux-appimage={s.cta_download_linux_appimage}
          data-label-linux-flatpak={s.cta_download_linux_flatpak}
          data-label-other-platforms={s.cta_other_platforms}
          data-label-installer={s.cta_installer_label}
          data-label-portable={s.cta_portable_label}
          data-label-arm={s.cta_arm_label}
          data-label-intel={s.cta_intel_label}
        >
          <noscript>
            <a class="btn btn-primary" href="https://github.com/antonio-orionus/Arroxy/releases/latest" target="_blank" rel="noopener">
              <Icon name="lucide:download" width={18} height={18} />
              {s.cta_download_os}
            </a>
          </noscript>
        </div>
      </div>

      <a class="hero-trust" href="https://github.com/antonio-orionus/Arroxy" target="_blank" rel="noopener" data-track="hero-github">{s.hero_trust}</a>

      <div id="platform-picker" style="display:none">
        <InstallerTabs
          ariaLabel={s.cta_other_platforms}
          labelWindows={s.cta_os_windows}
          labelMac={s.cta_os_mac}
          labelLinux={s.cta_os_linux}
          client:only="react"
        />
      </div>

      <details class="first-launch-help" id="first-launch-windows" style="display:none">
        <summary>{s.first_launch_label}</summary>
        <div class="first-launch-body" set:html={s.first_launch_windows_html} />
      </details>
      <details class="first-launch-help" id="first-launch-mac" style="display:none">
        <summary>{s.first_launch_label}</summary>
        <div class="first-launch-body" set:html={s.first_launch_mac_html} />
      </details>
      <details class="first-launch-help" id="first-launch-linux" style="display:none">
        <summary>{s.first_launch_label}</summary>
        <div class="first-launch-body" set:html={s.first_launch_linux_html} />
      </details>

      <p class="release-version" id="release-version">
        {s.release_label} <span id="version">{s.release_loading}</span> · Windows · macOS · Linux<span id="other-platforms-wrap" style="display:none"> · <button type="button" class="other-platforms-link" id="other-platforms-toggle">{s.cta_other_platforms}</button></span>
      </p>
    </div>

    <div class="demo-wrap">
      <div class="demo-frame">
        <img src="/assets/demo.gif" alt="Arroxy demo" loading="lazy" decoding="async" />
      </div>
    </div>
  </div>
</header>
