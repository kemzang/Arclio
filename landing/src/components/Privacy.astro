---
interface Props { s: Record<string, string>; }
const { s } = Astro.props;
---
<section>
  <div class="shell">
    <div class="section-head">
      <div class="section-eyebrow">{s.privacy_eyebrow}</div>
      <h2 set:html={s.privacy_h2_html} />
      <p class="section-sub">{s.privacy_sub}</p>
    </div>
    <div class="privacy-grid">
      <div class="privacy-card"><h3>{s.p1_h}</h3><p>{s.p1_p}</p></div>
      <div class="privacy-card"><h3>{s.p2_h}</h3><p>{s.p2_p}</p></div>
      <div class="privacy-card"><h3>{s.p3_h}</h3><p>{s.p3_p}</p></div>
      <div class="privacy-card"><h3>{s.p4_h}</h3><p>{s.p4_p}</p></div>
    </div>
  </div>
</section>
