---
interface Props { s: Record<string, string>; }
const { s } = Astro.props;
---
<section class="mid-cta">
  <div class="shell">
    <div class="mid-cta-inner">
      <div class="mid-cta-text">
        <h2>{s.mid_cta_h2}</h2>
        <p>{s.mid_cta_sub}</p>
      </div>
      <div id="mid-download-cta" aria-live="polite">
        <noscript>
          <a class="btn btn-primary" href="https://github.com/antonio-orionus/Arroxy/releases/latest" target="_blank" rel="noopener">{s.cta_download_os}</a>
        </noscript>
      </div>
    </div>
  </div>
</section>
