---
interface Props { s: Record<string, string>; }
const { s } = Astro.props;
---
<section id="install" class="scroll-mt-16">
  <div class="shell">
    <div class="section-head">
      <div class="section-eyebrow">{s.install_eyebrow}</div>
      <h2>{s.install_h2}</h2>
      <p class="section-sub">{s.install_sub}</p>
    </div>
    <div class="install-grid">
      <div class="install-card">
        <h3>Winget <span class="platform-badge">{s.badge_windows}</span></h3>
        <p class="desc">{s.winget_desc}</p>
        <div class="code-block">
          <span>winget install AntonioOrionus.Arroxy</span>
          <button class="copy-btn" data-copy="winget install AntonioOrionus.Arroxy">{s.copy_label}</button>
        </div>
      </div>
      <div class="install-card">
        <h3>Scoop <span class="platform-badge">{s.badge_windows}</span></h3>
        <p class="desc">{s.scoop_desc}</p>
        <div class="code-block">
          <span>scoop bucket add arroxy https://github.com/antonio-orionus/scoop-bucket && scoop install arroxy</span>
          <button class="copy-btn" data-copy="scoop bucket add arroxy https://github.com/antonio-orionus/scoop-bucket && scoop install arroxy">{s.copy_label}</button>
        </div>
      </div>
      <div class="install-card">
        <h3>Homebrew <span class="platform-badge">{s.badge_macos}</span></h3>
        <p class="desc">{s.brew_desc}</p>
        <div class="code-block">
          <span>brew tap antonio-orionus/arroxy && brew install --cask arroxy</span>
          <button class="copy-btn" data-copy="brew tap antonio-orionus/arroxy && brew install --cask arroxy">{s.copy_label}</button>
        </div>
      </div>
      <div class="install-card">
        <h3>{s.flatpak_h} <span class="platform-badge">{s.badge_linux}</span></h3>
        <p class="desc">{s.flatpak_desc}</p>
        <div class="code-block">
          <span>flatpak install --user Arroxy-*.flatpak</span>
          <button class="copy-btn" data-copy="flatpak install --user Arroxy-*.flatpak">{s.copy_label}</button>
        </div>
      </div>
      <div class="install-card">
        <h3>{s.direct_h} <span class="platform-badge">{s.badge_all}</span></h3>
        <p class="desc">{s.direct_desc}</p>
        <a class="btn btn-secondary" style="margin-top: 4px;" href="https://github.com/antonio-orionus/Arroxy/releases/latest" target="_blank" rel="noopener">{s.direct_btn}</a>
      </div>
    </div>
  </div>
</section>
