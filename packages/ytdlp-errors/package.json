	"homepage": "https://github.com/antonio-orionus/Arclio/tree/main/packages/ytdlp-errors#readme",
	"repository": {"type": "git", "url": "git+https://github.com/antonio-orionus/Arclio.git", "directory": "packages/ytdlp-errors"},
	"bugs": {"url": "https://github.com/antonio-orionus/Arclio/issues"},
