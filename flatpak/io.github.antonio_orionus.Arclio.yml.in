app-id: io.github.antonio_orionus.Arclio
base: org.electronjs.Electron2.BaseApp
base-version: '25.08'
runtime: org.freedesktop.Platform
runtime-version: '25.08'
sdk: org.freedesktop.Sdk
command: arclio.sh
separate-locales: false
finish-args:
  - --share=network
  - --share=ipc
  - --socket=wayland
  - --socket=fallback-x11
  - --device=dri
  - --filesystem=xdg-download
  - --filesystem=xdg-videos
  - --filesystem=xdg-music
  - --talk-name=org.freedesktop.Notifications

modules:
  - name: arclio
    buildsystem: simple
    build-commands:
      - for size in 64 128 256 512; do install -Dm644 icons/${size}x${size}.png share/icons/hicolor/${size}x${size}/apps/${FLATPAK_ID}.png; done
      - install -Dm644 ${FLATPAK_ID}.desktop share/applications/${FLATPAK_ID}.desktop
      - install -Dm644 ${FLATPAK_ID}.metainfo.xml share/metainfo/${FLATPAK_ID}.metainfo.xml
      - install -Dm755 arclio.sh bin/arclio.sh
      - install -Dm644 LICENSE share/licenses/${FLATPAK_ID}/LICENSE
      - rm -rf icons ${FLATPAK_ID}.desktop ${FLATPAK_ID}.metainfo.xml arclio.sh LICENSE
      - cp -r * ${FLATPAK_DEST}
    sources:
      - type: archive
        path: __ARCHIVE_PATH__
        sha256: __ARCHIVE_SHA256__
        only-arches:
          - x86_64
      - type: file
        path: io.github.antonio_orionus.Arclio.desktop
      - type: file
        path: io.github.antonio_orionus.Arclio.metainfo.xml
      - type: file
        path: arclio.sh
      - type: dir
        path: icons
        dest: icons
      - type: file
        path: ../LICENSE
