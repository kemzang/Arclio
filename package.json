{
  "name": "arroxy",
  "version": "0.3.1-beta.9",
  "description": "Arroxy - YouTube downloader app",
  "main": "out/main/index.js",
  "author": {
    "name": "Antonio Orionus",
    "email": "orionusAI@proton.me",
    "url": "https://x.com/OrionusAI"
  },
  "license": "MIT",
  "scripts": {
    "dev": "bun run embed:fetch:host && ELECTRON_DISABLE_SANDBOX=1 electron-vite dev",
    "embed:fetch:host": "bash scripts/build/fetch-embedded.sh $(node -e \"console.log(process.platform)\") $(node -e \"console.log(process.arch === 'arm64' ? 'arm64' : 'x64')\")",
    "clean": "rm -rf dist out",
    "build": "bun run typecheck && electron-vite build",
    "dist": "bun run clean && bun run build && electron-builder --publish never",
    "dist:win": "bun run clean && bun run build && electron-builder --win --publish never",
    "dist:win:nsis": "bun run clean && bun run build && electron-builder --win nsis --publish never",
    "dist:win:portable": "bun run clean && bun run build && electron-builder --win portable --publish never",
    "dist:mac": "bun run clean && bun run build && electron-builder --mac --publish never",
    "dist:linux": "bun run clean && bun run build && ELECTRON_BUILDER_COMPRESSION_LEVEL=5 electron-builder --linux --publish never",
    "dist:release": "bun run clean && bun run build && electron-builder --publish always",
    "dist:release:win": "bun run clean && bun run build && electron-builder --win --publish always",
    "dist:release:mac": "bun run clean && bun run build && electron-builder --mac --publish always",
    "dist:release:linux": "bun run clean && bun run build && ELECTRON_BUILDER_COMPRESSION_LEVEL=5 electron-builder --linux --publish always",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write src tests",
    "format:check": "prettier --check src tests",
    "knip": "knip",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "bun run build && xvfb-run -a playwright test",
    "test:browser": "playwright test --config playwright.browser.config.ts",
    "build:landing": "bun landing-src/build.mjs",
    "build:blog": "bun landing-src/blog/build.mjs",
    "build:readme": "bun readme-src/build.mjs",
    "build:docs": "bun run build:readme && bun run build:landing && bun run build:blog",
    "smoke": "bun scripts/smoke-youtube.ts",
    "smoke:pot": "bun scripts/smoke-pot-runner.ts",
    "release:beta": "bash scripts/release.sh beta",
    "release:stable": "bash scripts/release.sh stable",
    "prepare": "husky"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/outfit": "^5.2.8",
    "@fontsource/poppins": "^5.2.7",
    "@openpanel/sdk": "^1.3.1",
    "@tanstack/react-virtual": "^3.13.24",
    "@testing-library/dom": "^10.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-context-menu": "^4.1.2",
    "electron-log": "^5.4.3",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "electron-window-state": "^5.0.3",
    "extract-zip": "^2.0.1",
    "got": "^11",
    "i18next": "^26.0.8",
    "lucide-react": "^1.11.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.4",
    "shadcn": "^4.5.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/extract-zip": "^2.0.3",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.3.0",
    "electron-builder": "26.9.0",
    "electron-vite": "^5.0.0",
    "eslint": "^10.2.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-security": "^4.0.0",
    "globals": "^17.5.0",
    "gray-matter": "^4.0.3",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "knip": "^6.11.0",
    "lint-staged": "^16.4.0",
    "marked": "^18.0.3",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix --max-warnings=0"
    ],
    "src/**/*.css": "prettier --write",
    "tests/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix --max-warnings=0"
    ]
  }
}