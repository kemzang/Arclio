{
  "appId": "com.arroxy.app",
  "productName": "Arroxy",
  "afterPack": "./build/afterPack.mjs",
  "beforeBuild": "./build/beforeBuild.mjs",
  "directories": {
    "output": "dist",
    "buildResources": "build"
  },
  "files": ["out/**/*"],
  "extraResources": [
    {
      "from": "build/icon-tray.png",
      "to": "icon-tray.png"
    },
    {
      "from": "THIRD_PARTY_NOTICES.txt",
      "to": "THIRD_PARTY_NOTICES.txt"
    }
  ],
  "win": {
    "extraResources": [
      { "from": "build/embedded/win32-${arch}/ffmpeg.exe",  "to": "ffmpeg.exe" },
      { "from": "build/embedded/win32-${arch}/ffprobe.exe", "to": "ffprobe.exe" },
      { "from": "build/embedded/win32-${arch}/", "to": ".", "filter": ["*.dll"] }
    ],
    "target": [
      { "target": "nsis", "arch": ["x64"] },
      { "target": "portable", "arch": ["x64"] }
    ]
  },
  "nsis": {
    "oneClick": true,
    "perMachine": false,
    "allowElevation": false,
    "artifactName": "${productName}-Setup-${version}.${ext}"
  },
  "portable": {
    "artifactName": "${productName}-Portable-${version}.${ext}"
  },
  "mac": {
    "identity": null,
    "extraResources": [
      { "from": "build/embedded/darwin-${arch}/ffmpeg",  "to": "ffmpeg" },
      { "from": "build/embedded/darwin-${arch}/ffprobe", "to": "ffprobe" }
    ],
    "target": [{ "target": "dmg", "arch": ["arm64", "x64"] }],
    "artifactName": "${productName}-${version}-${arch}.${ext}"
  },
  "linux": {
    "extraResources": [
      { "from": "build/embedded/linux-${arch}/ffmpeg",  "to": "ffmpeg" },
      { "from": "build/embedded/linux-${arch}/ffprobe", "to": "ffprobe" },
      { "from": "build/embedded/linux-${arch}/", "to": ".", "filter": ["lib*.so*"] }
    ],
    "target": [
      { "target": "AppImage", "arch": ["x64"] },
      { "target": "tar.gz", "arch": ["x64"] }
    ],
    "artifactName": "${productName}-${version}.${ext}"
  },
  "publish": {
    "provider": "github",
    "owner": "antonio-orionus",
    "repo": "Arroxy"
  }
}
