msgctxt "wizard.url.networkPacing.tooltips.balanced"
msgid "Default. Adds short pauses and uses one download connection."
msgstr "Durtii. Eegaa gabaabaa dabalaa fi walqunnamtii buufata tokko fayyadama."

msgctxt "wizard.url.networkPacing.tooltips.careful"
msgid "Adds longer pauses for large playlists or networks that frequently hit limits."
msgstr "Eegaa dheeraaf playlist guddoo ykn network yeroo yeroon daangaa gahu dabalaa."

msgctxt "wizard.url.networkPacing.tooltips.custom"
msgid "Tune the advanced per-download controls yourself."
msgstr "Too'annoo ammayyaa buufata tokko tokkoos ofiin sirreessi."

msgctxt "wizard.url.networkPacing.tooltips.off"
msgid "Uses only the small baseline pauses Arroxy keeps for media and subtitles."
msgstr "Arroxy miidiyaa fi axxiinni qofaaf eegaa xiqaa qabaatutu fayyadama."

msgctxt "wizard.url.networkPacing.units.seconds"
msgid "sec"
msgstr "sec"

msgctxt "wizard.url.networkPacing.units.threads"
msgid "threads"
msgstr "threads"

msgctxt "wizard.url.placeholder"
msgid "https://..."
msgstr "https://www.youtube.com/watch?v=..."

msgctxt "wizard.url.playlistProbeLimit.current"
msgid "Current limit: {{count}} items"
msgstr "Daangaa ammaa: wantota {{count}}"

msgctxt "wizard.url.playlistProbeLimit.custom"
msgid "Custom…"
msgstr "Mifaan…"

msgctxt "wizard.url.playlistProbeLimit.customDialogCancel"
msgid "Cancel"
msgstr "Haquu"

msgctxt "wizard.url.playlistProbeLimit.customDialogDescription"
msgid "Use a whole number from {{min}} to {{max}}."
msgstr "Lakkoofsa guutuu {{min}} hanga {{max}} fayyadami."

msgctxt "wizard.url.playlistProbeLimit.customDialogSave"
msgid "Save limit"
msgstr "Daangaa kuusi"

msgctxt "wizard.url.playlistProbeLimit.customDialogTitle"
msgid "Custom playlist scan limit"
msgstr "Daangaa qorannaa playlist mifaan"

msgctxt "wizard.url.playlistProbeLimit.customValue"
msgid "Custom: {{count}} items"
msgstr "Mifaan: wantota {{count}}"

msgctxt "wizard.url.playlistProbeLimit.description"
msgid "Maximum entries Arroxy loads when a playlist, channel, or search result is opened."
msgstr "Playlist, chaanaalii, ykn filannoowwan barbaachaa yommuu banamu Arroxy galmeewwan baay'ina meeqa fe'u."

msgctxt "wizard.url.playlistProbeLimit.invalid"
msgid "Use a whole number from 1 to 5000"
msgstr "Lakkoofsa guutuu 1 hanga 5000 fayyadami"

msgctxt "wizard.url.playlistProbeLimit.label"
msgid "Playlist items to scan"
msgstr "Wantota playlist qoratamu"

msgctxt "wizard.url.playlistProbeLimit.option"
msgid "{{count}} items"
msgstr "Wantota {{count}}"

msgctxt "wizard.url.playlistProbeLimit.tooltip"
msgid "Maps to yt-dlp --playlist-end: Arroxy only asks for this many playlist, channel, or search entries while building the picker."
msgstr "yt-dlp --playlist-end waliin walsimsiisa: Arroxy filataa ijaarutti wantota playlist, chaanaalii, ykn barbaadaa lakkoofsa kana qofa gaafata."

