msgstr "Преузимање није успело. Провери интернет везу и покушај поново."

msgctxt "repair.hints.extractFailed"
msgid "Archive extraction failed. The download may be corrupt — retry."
msgstr "Распакивање архиве није успело. Преузимање може бити оштећено — покушај поново."

msgctxt "repair.hints.hashFailed"
msgid "Checksum mismatch on the downloaded file. Retry the download."
msgstr "Контролна сума преузете датотеке се не подудара. Поново преузми датотеку."

msgctxt "repair.hints.pairIncomplete"
msgid "ffmpeg and ffprobe must both be set as a matched pair."
msgstr "ffmpeg и ffprobe морају бити постављени заједно као усклађени пар."

msgctxt "repair.hints.permissionDenied"
msgid "The system refused to run the file. Pick a copy you trust or retry as admin."
msgstr "Систем је одбио да покрене датотеку. Изабери копију којој верујеш или покушај поново као администратор."

msgctxt "repair.hints.spawnFailed"
msgid "The file is missing or could not be launched. Pick a working copy."
msgstr "Датотека недостаје или не може да се покрене. Изабери исправну копију."

msgctxt "repair.hints.timeout"
msgid "The version probe timed out. The file may be hung — retry."
msgstr "Провера верзије је истекла. Датотека можда виси — покушај поново."

