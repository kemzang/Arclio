msgctxt "repair.hints.badExitCode"
msgid "The binary did not respond to --version. It may be corrupt or the wrong build."
msgstr "बाइनरी ने --version का जवाब नहीं दिया। यह दूषित या गलत बिल्ड हो सकती है।"

msgctxt "repair.hints.blockedOrQuarantined"
msgid "Windows blocked the file (SmartScreen / Defender). Pick an installed copy or whitelist the runtime folder."
msgstr "Windows ने फ़ाइल को ब्लॉक किया (SmartScreen / Defender)। इंस्टॉल की गई कॉपी चुनें या runtime फ़ोल्डर को श्वेतसूची में डालें।"

msgctxt "repair.hints.downloadFailed"
msgid "Download failed. Check your internet connection and retry."
msgstr "डाउनलोड विफल रहा। अपना इंटरनेट कनेक्शन जाँचें और पुनः प्रयास करें।"

msgctxt "repair.hints.extractFailed"
msgid "Archive extraction failed. The download may be corrupt — retry."
msgstr "आर्काइव निकालने में विफलता। डाउनलोड दूषित हो सकता है — पुनः प्रयास करें।"

msgctxt "repair.hints.hashFailed"
msgid "Checksum mismatch on the downloaded file. Retry the download."
msgstr "डाउनलोड की गई फ़ाइल का checksum मेल नहीं खाता। डाउनलोड फिर से करें।"

msgctxt "repair.hints.pairIncomplete"
msgid "ffmpeg and ffprobe must both be set as a matched pair."
msgstr "ffmpeg और ffprobe दोनों को मिलान जोड़ी के रूप में सेट करना होगा।"

msgctxt "repair.hints.permissionDenied"
msgid "The system refused to run the file. Pick a copy you trust or retry as admin."
msgstr "सिस्टम ने फ़ाइल चलाने से इनकार किया। कोई विश्वसनीय कॉपी चुनें या व्यवस्थापक के रूप में पुनः प्रयास करें।"

msgctxt "repair.hints.spawnFailed"
msgid "The file is missing or could not be launched. Pick a working copy."
msgstr "फ़ाइल मौजूद नहीं है या लॉन्च नहीं हो सकी। एक काम करने वाली कॉपी चुनें।"

msgctxt "repair.hints.timeout"
msgid "The version probe timed out. The file may be hung — retry."
msgstr "वर्शन जाँच का समय समाप्त हो गया। फ़ाइल रुकी हुई हो सकती है — पुनः प्रयास करें।"

msgctxt "repair.hints.unknown"
msgid "Could not be verified."
msgstr "सत्यापित नहीं किया जा सका।"

