msgctxt "wizard.url.playlistProbeLimit.customValue"
msgid "Custom: {{count}} items"
msgstr "カスタム：{{count}} 件"

msgctxt "wizard.url.playlistProbeLimit.description"
msgid "Maximum entries Arroxy loads when a playlist, channel, or search result is opened."
msgstr "プレイリスト、チャンネル、または検索結果を開いたときに Arroxy が読み込む最大エントリ数。"

msgctxt "wizard.url.playlistProbeLimit.invalid"
msgid "Use a whole number from 1 to 5000"
msgstr "1 から 5000 の整数を入力してください"

msgctxt "wizard.url.playlistProbeLimit.label"
msgid "Playlist items to scan"
msgstr "スキャンするプレイリストの項目数"

msgctxt "wizard.url.playlistProbeLimit.option"
msgid "{{count}} items"
msgstr "{{count}} 件"

msgctxt "wizard.url.playlistProbeLimit.tooltip"
msgid "Maps to yt-dlp --playlist-end: Arroxy only asks for this many playlist, channel, or search entries while building the picker."
msgstr "yt-dlp の --playlist-end に対応します：Arroxy はピッカーを構築する際、この件数のプレイリスト・チャンネル・検索エントリのみ取得します。"

msgctxt "wizard.url.proxy.clear"
msgid "Clear"
msgstr "クリア"

msgctxt "wizard.url.proxy.description"
msgid "Route traffic through a proxy — useful for geo-restricted content."
msgstr "プロキシ経由でトラフィックを転送 — 地域制限コンテンツに有効。"

msgctxt "wizard.url.proxy.label"
msgid "Proxy URL"
msgstr "Proxy URL"

msgctxt "wizard.url.proxy.placeholder"
msgid "http://host:port"
msgstr "http://host:port"

msgctxt "wizard.url.quickBulkAllFailed"
msgid "None of those URLs could be prepared"
msgstr "これらの URL はどれも準備できませんでした"

msgctxt "wizard.url.quickDownload"
msgid "Quick Download"
msgstr "クイックダウンロード"

msgctxt "wizard.url.quickDownloadTooltip"
msgid "Will download using: {{profileName}}"
msgstr "{{profileName}} を使用してダウンロードします"

msgctxt "wizard.url.quickFailed"
msgid "Couldn't add this one: {{error}}"
msgstr "追加できませんでした: {{error}}"

msgctxt "wizard.url.quickPartialFailed_one"
msgid "Queued what worked. {{count}} URL could not be prepared."
msgstr "成功したものをキューに追加しました。{{count}} 件の URL は準備できませんでした。"

msgctxt "wizard.url.quickPartialFailed_other"
msgid "Queued what worked. {{count}} URLs could not be prepared."
msgstr "成功したものをキューに追加しました。{{count}} 件の URL は準備できませんでした。"

msgctxt "wizard.url.quickPrepareFailed"
msgid "Queue item could not be prepared"
msgstr "キュー項目を準備できませんでした"

msgctxt "wizard.url.quickPreparing"
msgid "Preparing"
msgstr "準備中"

msgctxt "wizard.url.quickProbeFailed"
msgid "Probe failed"
msgstr "解析に失敗しました"

msgctxt "wizard.url.quickQueued"
msgid "Added to queue"
msgstr "キューに追加しました"

msgctxt "wizard.url.quickSingleOnly"
msgid "Paste a video, playlist, channel, or search URL to get started."
msgstr "開始するには、動画、プレイリスト、チャンネル、検索の URL を貼り付けてください。"

msgctxt "wizard.url.singleFilenameId.toggle"
msgid "Add video ID to single filenames"
msgstr "単体ファイル名に動画IDを追加"

msgctxt "wizard.url.singleFilenameId.toggleDescription"
msgid "Keeps one-off downloads unique when titles change or collide."
msgstr "タイトルが変わったり重複したりしても、単発ダウンロードを一意に保ちます。"

#~ msgctxt "wizard.url.bulkTooltip"
#~ msgid "Paste a list of individual URLs, preview the cleaned list, then queue them with one shared quality preset."
#~ msgstr "個別 URL のリストを貼り付け、整理後の一覧を確認してから、共通の品質プリセットでキューに追加します。"

#~ msgctxt "wizard.url.fetchFormatsTooltip"
#~ msgid "Choose formats, subtitles, folder, and playlist items step by step before queueing."
#~ msgstr "キューに追加する前に、形式、字幕、フォルダー、プレイリスト項目を手順ごとに選びます。"

#~ msgctxt "wizard.url.heading"
#~ msgid "Video URL"
#~ msgstr "YouTube URL"

#~ msgctxt "wizard.url.mascotIdle"
#~ msgid "Drop a link — YouTube or any of 2000+ sites ✨"
#~ msgstr "YouTubeのリンクを貼ってね (動画でもShortsでもOK) — 「形式を取得」を押せばすぐ取りかかるよ ✨"

#~ msgctxt "wizard.url.quickDownloadTooltip"
#~ msgid "Uses the active Download Profile and queues the URL without opening the setup steps."
#~ msgstr "保存済みまたは既定の設定を使い、設定手順を開かずにこの単一動画をキューへ追加します。"

#~ msgctxt "wizard.url.quickSingleOnly"
#~ msgid "Quick Download can use single videos, playlists, channels, searches, and Bulk URLs."
