msgctxt "wizard.formats.cookiesError.currentModeBrowser"
msgid "Browser"
msgstr "Πρόγραμμα περιήγησης"

msgctxt "wizard.formats.cookiesError.currentModeFile"
msgid "File"
msgstr "Αρχείο"

msgctxt "wizard.formats.cookiesError.currentModeLabel"
msgid "Cookies source"
msgstr "Πηγή cookies"

msgctxt "wizard.formats.cookiesError.dpapi.docsLinkLabel"
msgid "yt-dlp docs (issue #10927)"
msgstr "yt-dlp τεκμηρίωση (ζήτημα #10927)"

msgctxt "wizard.formats.cookiesError.dpapi.explanation"
msgid "Chrome 127 and newer encrypts cookies in a way other apps can't read on Windows. Try one of the workarounds below."
msgstr "Το Chrome 127 και νεότερες εκδόσεις κρυπτογραφούν τα cookies με τρόπο που άλλες εφαρμογές δεν μπορούν να διαβάσουν στα Windows. Δοκίμασε μία από τις παρακάτω λύσεις."

msgctxt "wizard.formats.cookiesError.dpapi.fixFileBody"
msgid "Export cookies from Chrome with a browser extension, then switch this app to File mode and pick the exported file."
msgstr "Εξήγαγε τα cookies από το Chrome με ένα επέκταση προγράμματος περιήγησης, μετά άλλαξε αυτή την εφαρμογή σε λειτουργία Αρχείο και επέλεξε το εξαχθέν αρχείο."

msgctxt "wizard.formats.cookiesError.dpapi.fixFileLabel"
msgid "Export cookies.txt"
msgstr "Εξαγωγή cookies.txt"

msgctxt "wizard.formats.cookiesError.dpapi.fixFirefoxBody"
msgid "Firefox doesn't use App-Bound Encryption. Open cookies settings and pick Firefox from the browser list."
msgstr "Το Firefox δεν χρησιμοποιεί App-Bound Encryption. Άνοιξε τις ρυθμίσεις cookies και επέλεξε Firefox από τη λίστα προγραμμάτων περιήγησης."

msgctxt "wizard.formats.cookiesError.dpapi.fixFirefoxLabel"
msgid "Switch to Firefox"
msgstr "Μετάβαση στο Firefox"

msgctxt "wizard.formats.cookiesError.dpapi.fixUnsafeBody"
msgid "Add --disable-features=LockProfileCookieDatabase to Chrome's launch shortcut. Warning: this invalidates previously encrypted cookies, so you'll be signed out of every site and need to log in again."
msgstr "Πρόσθεσε --disable-features=LockProfileCookieDatabase στη συντόμευση εκκίνησης του Chrome. Προειδοποίηση: αυτό ακυρώνει τα προηγουμένως κρυπτογραφημένα cookies, οπότε θα αποσυνδεθείς από κάθε ιστότοπο και θα χρειαστεί να συνδεθείς ξανά."

msgctxt "wizard.formats.cookiesError.dpapi.fixUnsafeLabel"
msgid "Launch Chrome with App-Bound Encryption disabled"
msgstr "Εκκίνηση Chrome με απενεργοποιημένο App-Bound Encryption"

msgctxt "wizard.formats.cookiesError.dpapi.heading"
msgid "Chrome cookies blocked by Windows encryption"
msgstr "Τα cookies του Chrome αποκλείστηκαν από την κρυπτογράφηση των Windows"

msgctxt "wizard.formats.cookiesError.explanationBrowser"
msgid "Cookies are read directly from the browser. If the browser is currently running, its cookie database may be locked (Chromium-family). The browser must also be signed in to YouTube. Try closing the browser, switching to a different browser, switching to File mode, or turning cookies off."
msgstr "Τα cookies διαβάζονται απευθείας από το πρόγραμμα περιήγησης. Αν τρέχει αυτή τη στιγμή, η βάση δεδομένων cookies μπορεί να είναι κλειδωμένη (οικογένεια Chromium). Το πρόγραμμα περιήγησης πρέπει επίσης να είναι συνδεδεμένο στο YouTube. Δοκίμασε να το κλείσεις, να χρησιμοποιήσεις διαφορετικό πρόγραμμα, να μεταβείς σε λειτουργία αρχείου ή να απενεργοποιήσεις τα cookies."

msgctxt "wizard.formats.cookiesError.explanationFile"
msgid "Your cookies file might be empty, expired, or in the wrong format (yt-dlp expects Netscape cookies.txt). Try re-exporting cookies, picking a different file, switching to Browser mode, or turning cookies off."
msgstr "Το αρχείο cookies μπορεί να είναι κενό, ληγμένο ή σε λάθος μορφή (το yt-dlp αναμένει Netscape cookies.txt). Δοκίμασε να εξάγεις ξανά τα cookies, να επιλέξεις διαφορετικό αρχείο, να μεταβείς σε λειτουργία προγράμματος περιήγησης ή να απενεργοποιήσεις τα cookies."

msgctxt "wizard.formats.cookiesError.heading"
msgid "Cookies might be the cause"
msgstr "Τα cookies μπορεί να φταίνε"

msgctxt "wizard.formats.cookiesError.needsCookies.body"
msgid "yt-dlp couldn't access this video without authentication. Configure cookies in advanced settings — point them at a browser you're already signed in to, or import a cookies.txt file."
msgstr "Το yt-dlp δεν μπόρεσε να αποκτήσει πρόσβαση σε αυτό το βίντεο χωρίς έλεγχο ταυτότητας. Ρύθμισε τα cookies στις ρυθμίσεις για προχωρημένους — επίλεξε πρόγραμμα περιήγησης στο οποίο είσαι ήδη συνδεδεμένος, ή εισήγαγε αρχείο cookies.txt."

msgctxt "wizard.formats.cookiesError.needsCookies.heading"
