msgstr "Οι ενεργές λήψεις κρατούν το τρέχον όριο. Παύση + Συνέχεια για εφαρμογή αλλαγών."

msgctxt "wizard.url.limitRate.custom"
msgid "Custom…"
msgstr "Προσαρμογή…"

msgctxt "wizard.url.limitRate.customPlaceholder"
msgid "e.g. 750K or 1.5M"
msgstr "π.χ. 750K ή 1.5M"

msgctxt "wizard.url.limitRate.description"
msgid "Cap bandwidth for media downloads. Request pacing below is usually the stronger rate-limit lever."
msgstr "Περιόρισε το bandwidth για λήψεις πολυμέσων. Ο ρυθμός αιτημάτων παρακάτω είναι συνήθως ισχυρότερος μοχλός ορίων."

msgctxt "wizard.url.limitRate.invalid"
msgid "Use a number followed by K or M (e.g. 500K, 1.5M)"
msgstr "Χρησιμοποίησε αριθμό με K ή M (π.χ. 500K, 1.5M)"

msgctxt "wizard.url.limitRate.label"
msgid "Download speed limit"
msgstr "Όριο ταχύτητας λήψης"

msgctxt "wizard.url.limitRate.off"
msgid "Off"
msgstr "Ανενεργό"

msgctxt "wizard.url.mascotBusy"
msgid "Downloading in the background… I can multitask 😎"
msgstr "Λήψη στο παρασκήνιο… Ξέρω να κάνω πολλά μαζί 😎"

msgctxt "wizard.url.mascotIdle"
msgid "Drop a link and let Arroxy pull it ✨"
msgstr "Ρίξε έναν σύνδεσμο και άσε το Arroxy να το κατεβάσει ✨"

msgctxt "wizard.url.networkPacing.description"
msgid "Add small waits during each download so Arroxy does not hit the site too aggressively. Values are seconds unless noted."
msgstr "Προσθέτει μικρές παύσεις κατά τη διάρκεια κάθε λήψης ώστε το Arroxy να μην πιέζει υπερβολικά τον ιστότοπο. Οι τιμές είναι σε δευτερόλεπτα εκτός αν αναφέρεται διαφορετικά."

msgctxt "wizard.url.networkPacing.fields.concurrentFragments"
msgid "Download connections"
msgstr "Συνδέσεις λήψης"

msgctxt "wizard.url.networkPacing.fields.maxSleepInterval"
msgid "Pause before media starts: max"
msgstr "Παύση πριν ξεκινήσει το μέσο: μέγιστο"

msgctxt "wizard.url.networkPacing.fields.sleepInterval"
msgid "Pause before media starts: min"
msgstr "Παύση πριν ξεκινήσει το μέσο: ελάχιστο"

msgctxt "wizard.url.networkPacing.fields.sleepRequests"
msgid "Wait between metadata checks"
msgstr "Αναμονή μεταξύ ελέγχων μεταδεδομένων"

msgctxt "wizard.url.networkPacing.fields.sleepSubtitles"
msgid "Wait before subtitle files"
msgstr "Αναμονή πριν τα αρχεία υποτίτλων"

msgctxt "wizard.url.networkPacing.heading"
msgid "Gentle downloads"
msgstr "Ήπιες λήψεις"

msgctxt "wizard.url.networkPacing.presetLabel"
msgid "How cautious should Arroxy be?"
msgstr "Πόσο προσεκτικό πρέπει να είναι το Arroxy;"

msgctxt "wizard.url.networkPacing.presets.balanced"
msgid "Balanced"
msgstr "Ισορροπημένο"

msgctxt "wizard.url.networkPacing.presets.careful"
msgid "Careful"
msgstr "Προσεκτικό"

msgctxt "wizard.url.networkPacing.presets.custom"
msgid "Custom"
msgstr "Προσαρμοσμένο"

msgctxt "wizard.url.networkPacing.presets.off"
msgid "Off"
msgstr "Απενεργοποιημένο"

msgctxt "wizard.url.networkPacing.summary"
msgid "Waits: {{requests}} between checks, {{downloads}} before media starts, {{subtitles}} before subtitle files. Connections: {{fragments}}."
msgstr "Παύσεις: {{requests}} μεταξύ ελέγχων, {{downloads}} πριν ξεκινήσει το μέσο, {{subtitles}} πριν τα αρχεία υποτίτλων. Συνδέσεις: {{fragments}}."

msgctxt "wizard.url.networkPacing.tooltip"
msgid "These waits happen inside each download. Arroxy still keeps normal queued downloads one-at-a-time."
msgstr "Αυτές οι παύσεις γίνονται μέσα σε κάθε λήψη. Το Arroxy εξακολουθεί να κρατά τις κανονικές λήψεις σε ουρά μία τη φορά."

msgctxt "wizard.url.networkPacing.tooltips.balanced"
msgid "Default. Adds short pauses and uses one download connection."
msgstr "Προεπιλογή. Προσθέτει σύντομες παύσεις και χρησιμοποιεί μία σύνδεση λήψης."

msgctxt "wizard.url.networkPacing.tooltips.careful"
msgid "Adds longer pauses for large playlists or networks that frequently hit limits."
msgstr "Προσθέτει μεγαλύτερες παύσεις για μεγάλες playlist ή δίκτυα που συχνά φτάνουν στα όρια."

msgctxt "wizard.url.networkPacing.tooltips.custom"
msgid "Tune the advanced per-download controls yourself."
msgstr "Ρύθμισε μόνος σου τους σύνθετους ελέγχους ανά λήψη."

msgctxt "wizard.url.networkPacing.tooltips.off"
msgid "Uses only the small baseline pauses Arroxy keeps for media and subtitles."
msgstr "Χρησιμοποιεί μόνο τις μικρές βασικές παύσεις που κρατά το Arroxy για μέσα και υποτίτλους."

msgctxt "wizard.url.networkPacing.units.seconds"
msgid "sec"
msgstr "δευτ."

msgctxt "wizard.url.networkPacing.units.threads"
msgid "threads"
msgstr "νήματα"

msgctxt "wizard.url.placeholder"
msgid "https://..."
msgstr "https://www.youtube.com/watch?v=..."

msgctxt "wizard.url.playlistProbeLimit.current"
msgid "Current limit: {{count}} items"
msgstr "Τρέχον όριο: {{count}} στοιχεία"

msgctxt "wizard.url.playlistProbeLimit.custom"
msgid "Custom…"
msgstr "Προσαρμοσμένο…"

msgctxt "wizard.url.playlistProbeLimit.customDialogCancel"
msgid "Cancel"
msgstr "Άκυρο"

msgctxt "wizard.url.playlistProbeLimit.customDialogDescription"
msgid "Use a whole number from {{min}} to {{max}}."
msgstr "Χρησιμοποίησε έναν ακέραιο από {{min}} έως {{max}}."

msgctxt "wizard.url.playlistProbeLimit.customDialogSave"
msgid "Save limit"
msgstr "Αποθήκευση ορίου"

msgctxt "wizard.url.playlistProbeLimit.customDialogTitle"
msgid "Custom playlist scan limit"
msgstr "Προσαρμοσμένο όριο σάρωσης playlist"

msgctxt "wizard.url.playlistProbeLimit.customValue"
msgid "Custom: {{count}} items"
msgstr "Προσαρμοσμένο: {{count}} στοιχεία"

msgctxt "wizard.url.playlistProbeLimit.description"
msgid "Maximum entries Arroxy loads when a playlist, channel, or search result is opened."
msgstr "Μέγιστος αριθμός εγγραφών που φορτώνει το Arroxy όταν ανοίγει playlist, κανάλι ή αποτέλεσμα αναζήτησης."

msgctxt "wizard.url.playlistProbeLimit.invalid"
msgid "Use a whole number from 1 to 5000"
msgstr "Χρησιμοποίησε έναν ακέραιο από 1 έως 5000"

msgctxt "wizard.url.playlistProbeLimit.label"
msgid "Playlist items to scan"
msgstr "Στοιχεία playlist για σάρωση"

msgctxt "wizard.url.playlistProbeLimit.option"
msgid "{{count}} items"
msgstr "{{count}} στοιχεία"

msgctxt "wizard.url.playlistProbeLimit.tooltip"
msgid "Maps to yt-dlp --playlist-end: Arroxy only asks for this many playlist, channel, or search entries while building the picker."
msgstr "Αντιστοιχεί στο yt-dlp --playlist-end: το Arroxy ζητά μόνο τόσες εγγραφές playlist, καναλιού ή αναζήτησης κατά τη δημιουργία του picker."

msgctxt "wizard.url.proxy.clear"
msgid "Clear"
msgstr "Εκκαθάριση"

msgctxt "wizard.url.proxy.description"
msgid "Route traffic through a proxy — useful for geo-restricted content."
msgstr "Δρομολόγηση κίνησης μέσω proxy — χρήσιμο για περιεχόμενο με γεωγραφικούς περιορισμούς."

msgctxt "wizard.url.proxy.label"
msgid "Proxy URL"
msgstr "Proxy URL"

msgctxt "wizard.url.proxy.placeholder"
msgid "http://host:port"
msgstr "http://host:port"

msgctxt "wizard.url.quickDownload"
msgid "Quick Download"
msgstr "Γρήγορη λήψη"

msgctxt "wizard.url.quickDownloadTooltip"
msgid "Will download using: {{profileName}}"
msgstr "Θα γίνει λήψη με: {{profileName}}"

msgctxt "wizard.url.quickFailed"
msgid "Couldn't add this one: {{error}}"
msgstr "Δεν ήταν δυνατή η προσθήκη: {{error}}"

msgctxt "wizard.url.quickPrepareFailed"
msgid "Queue item could not be prepared"
msgstr "Δεν ήταν δυνατή η προετοιμασία του στοιχείου ουράς"

msgctxt "wizard.url.quickPreparing"
msgid "Preparing"
msgstr "Προετοιμασία"

msgctxt "wizard.url.quickProbeFailed"
msgid "Probe failed"
msgstr "Ο έλεγχος απέτυχε"

msgctxt "wizard.url.quickQueued"
msgid "Added to queue"
msgstr "Προστέθηκε στην ουρά"

msgctxt "wizard.url.quickSingleOnly"
msgid "Paste a video, playlist, channel, or search URL to get started."
msgstr "Επικόλλησε URL βίντεο, playlist, καναλιού ή αναζήτησης για να ξεκινήσεις."

msgctxt "wizard.url.singleFilenameId.toggle"
msgid "Add video ID to single filenames"
msgstr "Προσθήκη ID βίντεο στα μεμονωμένα ονόματα αρχείων"

msgctxt "wizard.url.singleFilenameId.toggleDescription"
msgid "Keeps one-off downloads unique when titles change or collide."
msgstr "Κρατά τις μεμονωμένες λήψεις μοναδικές όταν αλλάζουν ή συμπίπτουν οι τίτλοι."

