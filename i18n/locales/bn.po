msgctxt "wizard.formats.audioOnlyOption"
msgid "Audio only (no video)"
msgstr "শুধু অডিও (ভিডিও ছাড়া)"

msgctxt "wizard.formats.botWall.bodyDisabled"
msgid "Cookies are configured but turned off. Enable them and retry to get the full list, or change network and retry."
msgstr "কুকিজ কনফিগার করা আছে কিন্তু বন্ধ। সম্পূর্ণ তালিকা পেতে চালু করে আবার চেষ্টা করুন, অথবা নেটওয়ার্ক পরিবর্তন করে আবার চেষ্টা করুন।"

msgctxt "wizard.formats.botWall.bodyEnabled"
msgid "Even with cookies, YouTube limited this probe. Try again later or switch network."
msgstr "কুকিজ থাকলেও YouTube এই প্রোব সীমাবদ্ধ করেছে। পরে আবার চেষ্টা করুন বা নেটওয়ার্ক পরিবর্তন করুন।"

msgctxt "wizard.formats.botWall.bodyUnconfigured"
msgid "The format list may be incomplete. Set up cookies in advanced settings, or change network and retry."
msgstr "ফরম্যাট তালিকা অসম্পূর্ণ হতে পারে। উন্নত সেটিংসে কুকিজ সেট করুন, অথবা নেটওয়ার্ক পরিবর্তন করে আবার চেষ্টা করুন।"

msgctxt "wizard.formats.botWall.enableRetryCta"
msgid "Enable cookies and retry"
msgstr "কুকিজ চালু করে আবার চেষ্টা করুন"

msgctxt "wizard.formats.botWall.heading"
msgid "Probe was limited"
msgstr "YouTube এই প্রোবটি সীমাবদ্ধ করেছে"

msgctxt "wizard.formats.botWall.retryCta"
msgid "Retry"
msgstr "আবার চেষ্টা করুন"

msgctxt "wizard.formats.convert.bitrate"
msgid "Bitrate"
msgstr "বিটরেট"

msgctxt "wizard.formats.convert.label"
msgid "Convert"
msgstr "কনভার্ট করুন"

msgctxt "wizard.formats.convert.lossyLabel"
msgid "{{target}} {{bitrate}} kbps"
msgstr "{{target}} {{bitrate}} kbps"

msgctxt "wizard.formats.convert.requiresAudioOnly"
msgid "Audio conversion requires audio-only mode (deselect the video pick)."
msgstr "অডিও কনভার্শনের জন্য শুধু অডিও মোড প্রয়োজন (ভিডিও পিক বাতিল করুন)।"

msgctxt "wizard.formats.convert.requiresLossy"
msgid "A native stream is selected — bitrate only applies when converting to mp3, m4a, or opus."
msgstr "একটি নেটিভ স্ট্রিম নির্বাচিত — বিটরেট শুধুমাত্র mp3, m4a, বা opus-এ কনভার্ট করার সময় প্রযোজ্য।"

msgctxt "wizard.formats.convert.uncompressed"
msgid "Convert · uncompressed"
msgstr "কনভার্ট · আনকম্প্রেসড"

msgctxt "wizard.formats.convert.wavLabel"
msgid "WAV (uncompressed)"
msgstr "WAV (uncompressed)"

msgctxt "wizard.formats.cookiesError.currentModeBrowser"
msgid "Browser"
msgstr "ব্রাউজার"

msgctxt "wizard.formats.cookiesError.currentModeFile"
msgid "File"
msgstr "ফাইল"

msgctxt "wizard.formats.cookiesError.currentModeLabel"
msgid "Cookies source"
msgstr "কুকিজের উৎস"

msgctxt "wizard.formats.cookiesError.dpapi.docsLinkLabel"
msgid "yt-dlp docs (issue #10927)"
msgstr "yt-dlp ডকস (ইস্যু #10927)"

msgctxt "wizard.formats.cookiesError.dpapi.explanation"
msgid "Chrome 127 and newer encrypts cookies in a way other apps can't read on Windows. Try one of the workarounds below."
msgstr "Chrome 127 এবং পরবর্তী সংস্করণ Windows-এ কুকিজ এমনভাবে এনক্রিপ্ট করে যা অন্য অ্যাপ পড়তে পারে না। নিচের যেকোনো একটি সমাধান চেষ্টা করুন।"

msgctxt "wizard.formats.cookiesError.dpapi.fixFileBody"
msgid "Export cookies from Chrome with a browser extension, then switch this app to File mode and pick the exported file."
msgstr "Chrome থেকে ব্রাউজার এক্সটেনশন দিয়ে কুকিজ এক্সপোর্ট করুন, তারপর এই অ্যাপটি File মোডে পরিবর্তন করে এক্সপোর্ট করা ফাইলটি বেছে নিন।"

msgctxt "wizard.formats.cookiesError.dpapi.fixFileLabel"
msgid "Export cookies.txt"
msgstr "cookies.txt এক্সপোর্ট করুন"

msgctxt "wizard.formats.cookiesError.dpapi.fixFirefoxBody"
msgid "Firefox doesn't use App-Bound Encryption. Open cookies settings and pick Firefox from the browser list."
msgstr "Firefox App-Bound Encryption ব্যবহার করে না। কুকিজ সেটিংস খুলুন এবং ব্রাউজার তালিকা থেকে Firefox বেছে নিন।"

msgctxt "wizard.formats.cookiesError.dpapi.fixFirefoxLabel"
msgid "Switch to Firefox"
msgstr "Firefox-এ যান"

msgctxt "wizard.formats.cookiesError.dpapi.fixUnsafeBody"
msgid "Add --disable-features=LockProfileCookieDatabase to Chrome's launch shortcut. Warning: this invalidates previously encrypted cookies, so you'll be signed out of every site and need to log in again."
msgstr "Chrome-এর লঞ্চ শর্টকাটে --disable-features=LockProfileCookieDatabase যোগ করুন। সতর্কতা: এটি আগে এনক্রিপ্ট করা কুকিজ অকার্যকর করে দেয়, তাই আপনি প্রতিটি সাইট থেকে লগ আউট হয়ে যাবেন এবং আবার লগ ইন করতে হবে।"

msgctxt "wizard.formats.cookiesError.dpapi.fixUnsafeLabel"
msgid "Launch Chrome with App-Bound Encryption disabled"
msgstr "App-Bound Encryption নিষ্ক্রিয় করে Chrome চালু করুন"

msgctxt "wizard.formats.cookiesError.dpapi.heading"
msgid "Chrome cookies blocked by Windows encryption"
msgstr "Windows এনক্রিপশন দ্বারা Chrome কুকিজ ব্লক হয়েছে"

msgctxt "wizard.formats.cookiesError.explanationBrowser"
msgid "Cookies are read directly from the browser. If the browser is currently running, its cookie database may be locked (Chromium-family). The browser must also be signed in to YouTube. Try closing the browser, switching to a different browser, switching to File mode, or turning cookies off."
msgstr "কুকিজ সরাসরি ব্রাউজার থেকে পড়া হয়। ব্রাউজার এখন চলছে থাকলে, এর কুকি ডেটাবেস লক থাকতে পারে (Chromium-পরিবার)। ব্রাউজারটি YouTube-এ সাইন ইন থাকতে হবে। ব্রাউজার বন্ধ করুন, ভিন্ন ব্রাউজারে স্যুইচ করুন, ফাইল মোডে স্যুইচ করুন, অথবা কুকিজ বন্ধ করে দেখুন।"

msgctxt "wizard.formats.cookiesError.explanationFile"
msgid "Your cookies file might be empty, expired, or in the wrong format (yt-dlp expects Netscape cookies.txt). Try re-exporting cookies, picking a different file, switching to Browser mode, or turning cookies off."
msgstr "আপনার কুকিজ ফাইলটি খালি, মেয়াদ শেষ বা ভুল ফরম্যাটে থাকতে পারে (yt-dlp Netscape cookies.txt আশা করে)। কুকিজ পুনরায় এক্সপোর্ট করুন, ভিন্ন ফাইল বেছে নিন, ব্রাউজার মোডে স্যুইচ করুন, অথবা কুকিজ বন্ধ করে দেখুন।"

msgctxt "wizard.formats.cookiesError.heading"
msgid "Cookies might be the cause"
msgstr "কুকিজ কারণ হতে পারে"

msgctxt "wizard.formats.cookiesError.needsCookies.body"
msgid "yt-dlp couldn't access this video without authentication. Configure cookies in advanced settings — point them at a browser you're already signed in to, or import a cookies.txt file."
msgstr "yt-dlp প্রমাণীকরণ ছাড়া এই ভিডিওতে অ্যাক্সেস করতে পারেনি। উন্নত সেটিংসে কুকিজ কনফিগার করুন — আপনি ইতিমধ্যে সাইন ইন করা কোনো ব্রাউজার দিন, বা cookies.txt ফাইল আমদানি করুন।"

msgctxt "wizard.formats.cookiesError.needsCookies.heading"
msgid "This site requires sign-in"
msgstr "এই সাইটে সাইন-ইন প্রয়োজন"

msgctxt "wizard.formats.cookiesError.openSettingsCta"
msgid "Open cookies settings"
msgstr "কুকিজ সেটিংস খুলুন"

msgctxt "wizard.formats.keepAudio"
msgid "Keep as-is"
msgstr "যেমন আছে রাখুন"

msgctxt "wizard.formats.keepAudioMeta"
msgid "Built-in audio"
msgstr "বিল্ট-ইন অডিও"

msgctxt "wizard.formats.loadingAria"
msgid "Loading formats"
msgstr "ফরম্যাট লোড হচ্ছে"

msgctxt "wizard.formats.loadingHint"
msgid "Please wait until probing finishes — playlists and searches can take a while."
msgstr "প্রোবিং শেষ হওয়া পর্যন্ত অপেক্ষা করুন — প্লেলিস্ট ও অনুসন্ধানে একটু বেশি সময় লাগতে পারে।"

msgctxt "wizard.formats.mascot"
msgid "Best + Best = max quality. I'd pick that!"
msgstr "সেরা + সেরা = সর্বোচ্চ মান। আমি এটাই বেছে নিতাম!"

msgctxt "wizard.formats.noAudio"
msgid "No audio"
msgstr "অডিও নেই"

msgctxt "wizard.formats.quickPresets"
msgid "Quick presets"
msgstr "দ্রুত প্রিসেট"

msgctxt "wizard.formats.sizeUnknown"
msgid "Size unknown"
msgstr "আকার অজানা"

msgctxt "wizard.formats.skipToConfirm"
msgid "Skip to confirm"
msgstr "নিশ্চিতে যান"

msgctxt "wizard.formats.skipToConfirmTooltip"
msgid "Uses your saved preferences for all remaining steps. To change a setting, continue step by step instead — your choice will be saved for next time."
msgstr "বাকি সকল ধাপের জন্য আপনার সংরক্ষিত পছন্দ ব্যবহার করে। কোনো সেটিং পরিবর্তন করতে, পরিবর্তে ধাপে ধাপে এগিয়ে যান — আপনার পছন্দ পরের বার সংরক্ষিত হবে।"

msgctxt "wizard.formats.sniffing"
msgid "Sniffing out the best formats for you…"
msgstr "আপনার জন্য সেরা ফরম্যাট খুঁজছি…"

msgctxt "wizard.formats.total"
msgid "Total"
msgstr "মোট"

msgctxt "wizard.formats.video"
msgid "Video"
msgstr "ভিডিও"

msgctxt "wizard.formats.videoOnly"
msgid "Video only"
msgstr "শুধু ভিডিও"

msgctxt "wizard.mixedPrompt.body"
msgid "Want only the video you clicked, or pick from the playlist? You'll choose specific videos or a range next."
msgstr "শুধু যে ভিডিওতে ক্লিক করেছিলেন সেটি চান, নাকি Playlist থেকে বেছে নিতে চান? পরে নির্দিষ্ট ভিডিও বা রেঞ্জ বেছে নেবেন।"

msgctxt "wizard.mixedPrompt.pickFromPlaylist"
msgid "Pick from playlist"
msgstr "Playlist থেকে বেছে নিন"

msgctxt "wizard.mixedPrompt.playlistLimit"
msgid "Playlist probe limit: {{count}} items"
msgstr "প্লেলিস্ট প্রোব সীমা: {{count}}টি আইটেম"

msgctxt "wizard.mixedPrompt.playlistTooltip"
msgid "Uses yt-dlp playlist mode and fetches up to your playlist probe limit before showing the picker."
msgstr "yt-dlp-এর প্লেলিস্ট মোড ব্যবহার করে এবং পিকার দেখানোর আগে আপনার সীমা পর্যন্ত আইটেম আনে।"

msgctxt "wizard.mixedPrompt.singleTooltip"
msgid "Uses yt-dlp single-video mode so the playlist attached to this URL is ignored."
msgstr "yt-dlp-এর একক-ভিডিও মোড ব্যবহার করে, তাই এই URL-এর সঙ্গে থাকা প্লেলিস্ট উপেক্ষা করা হয়।"

msgctxt "wizard.mixedPrompt.singleVideo"
msgid "Just this one"
msgstr "শুধু এটি"

msgctxt "wizard.mixedPrompt.title"
msgid "This link has a playlist"
msgstr "এই লিংকে একটি Playlist আছে"

msgctxt "wizard.output.embedChapters.description"
msgid "Chapter markers navigable in any modern player."
msgstr "যেকোনো আধুনিক প্লেয়ারে নেভিগেট করা যায় এমন চ্যাপ্টার মার্কার।"

msgctxt "wizard.output.embedChapters.label"
msgid "Embed chapters"
msgstr "চ্যাপ্টার এম্বেড করুন"

msgctxt "wizard.output.embedMetadata.description"
msgid "Title, artist, description, and upload date written into the file."
msgstr "শিরোনাম, শিল্পী, বিবরণ এবং আপলোড তারিখ ফাইলে লেখা হবে।"

msgctxt "wizard.output.embedMetadata.label"
msgid "Embed metadata"
msgstr "মেটাডেটা এম্বেড করুন"

msgctxt "wizard.output.embedThumbnail.description"
msgid "Cover art inside the file. WebM video will be remuxed to MKV; skipped when subtitles are embedded."
msgstr "ফাইলের ভেতরে কভার আর্ট। WebM ভিডিও MKV-তে রিমাক্স করা হবে; সাবটাইটেল এম্বেড থাকলে বাদ দেওয়া হবে।"

msgctxt "wizard.output.embedThumbnail.label"
msgid "Embed thumbnail"
msgstr "থাম্বনেইল এম্বেড করুন"

msgctxt "wizard.output.writeDescription.description"
msgid "Saves the video description as a .description text file next to the download."
msgstr "ভিডিও বিবরণ ডাউনলোডের পাশে .description টেক্সট ফাইল হিসেবে সেভ করে।"

msgctxt "wizard.output.writeDescription.label"
msgid "Save description"
msgstr "বিবরণ সেভ করুন"

msgctxt "wizard.output.writeM3u.description"
msgid "Save an .m3u playlist alongside the videos so they open in order in your media player."
msgstr "ভিডিওগুলোর পাশে .m3u প্লেলিস্ট সংরক্ষণ করে যাতে মিডিয়া প্লেয়ারে ক্রম অনুযায়ী খোলে।"

msgctxt "wizard.output.writeM3u.label"
msgid "Generate .m3u playlist file"
