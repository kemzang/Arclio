msgid "Music"
msgstr "Музика"

msgctxt "wizard.url.features.youtube.playlist"
msgid "Playlists"
msgstr "Плейлисти"

msgctxt "wizard.url.features.youtube.podcast"
msgid "Podcasts"
msgstr "Подкасти"

msgctxt "wizard.url.features.youtube.short"
msgid "Shorts"
msgstr "Shorts"

msgctxt "wizard.url.features.youtube.video"
msgid "Videos"
msgstr "Відео"

msgctxt "wizard.url.fetchFormatsTooltip"
msgid "Step-by-step wizard. Choose format, quality, and more."
msgstr "Покроковий майстер. Виберіть формат, якість та інші параметри."

msgctxt "wizard.url.heading"
msgid "Download from URL"
msgstr "Завантажити з URL"

msgctxt "wizard.url.interactiveDownload"
msgid "Interactive Download"
msgstr "Отримати формати"

msgctxt "wizard.url.limitRate.activeWarning"
msgid "Active downloads keep their current limit. Pause + Resume to apply changes."
msgstr "Активні завантаження зберігають поточний ліміт. Пауза + Продовжити застосує зміни."

msgctxt "wizard.url.limitRate.custom"
msgid "Custom…"
msgstr "Власне…"

msgctxt "wizard.url.limitRate.customPlaceholder"
msgid "e.g. 750K or 1.5M"
msgstr "наприклад 750K або 1.5M"

msgctxt "wizard.url.limitRate.description"
msgid "Cap bandwidth for media downloads. Request pacing below is usually the stronger rate-limit lever."
msgstr "Обмежує пропускну здатність для медіазавантажень. Інтервали запитів нижче зазвичай сильніше впливають на ліміти."

msgctxt "wizard.url.limitRate.invalid"
msgid "Use a number followed by K or M (e.g. 500K, 1.5M)"
msgstr "Введи число з K або M (наприклад 500K, 1.5M)"

msgctxt "wizard.url.limitRate.label"
msgid "Download speed limit"
msgstr "Обмеження швидкості завантаження"

msgctxt "wizard.url.limitRate.off"
msgid "Off"
msgstr "Вимкнено"

msgctxt "wizard.url.mascotBusy"
msgid "Downloading in the background… I can multitask 😎"
msgstr "Завантажую у фоні… можу робити кілька справ одночасно 😎"

msgctxt "wizard.url.mascotIdle"
msgid "Drop a link and let Arroxy pull it ✨"
msgstr "Кинь посилання, а Arroxy його забере ✨"

msgctxt "wizard.url.networkPacing.description"
msgid "Add small waits during each download so Arroxy does not hit the site too aggressively. Values are seconds unless noted."
msgstr "Додає невеликі паузи під час кожного завантаження, щоб Arroxy не звертався до сайту надто агресивно. Значення в секундах, якщо не зазначено інше."

msgctxt "wizard.url.networkPacing.fields.concurrentFragments"
msgid "Download connections"
msgstr "З'єднань для завантаження"

msgctxt "wizard.url.networkPacing.fields.maxSleepInterval"
msgid "Pause before media starts: max"
msgstr "Пауза перед початком медіа: макс"

msgctxt "wizard.url.networkPacing.fields.sleepInterval"
msgid "Pause before media starts: min"
msgstr "Пауза перед початком медіа: мін"

msgctxt "wizard.url.networkPacing.fields.sleepRequests"
msgid "Wait between metadata checks"
msgstr "Очікування між перевірками метаданих"

msgctxt "wizard.url.networkPacing.fields.sleepSubtitles"
msgid "Wait before subtitle files"
msgstr "Очікування перед файлами субтитрів"

msgctxt "wizard.url.networkPacing.heading"
msgid "Gentle downloads"
msgstr "Бережні завантаження"

msgctxt "wizard.url.networkPacing.presetLabel"
msgid "How cautious should Arroxy be?"
msgstr "Наскільки обережним має бути Arroxy?"

msgctxt "wizard.url.networkPacing.presets.balanced"
msgid "Balanced"
msgstr "Збалансовано"

msgctxt "wizard.url.networkPacing.presets.careful"
msgid "Careful"
msgstr "Обережно"

msgctxt "wizard.url.networkPacing.presets.custom"
msgid "Custom"
msgstr "Налаштувати"

msgctxt "wizard.url.networkPacing.presets.off"
msgid "Off"
msgstr "Вимк"

msgctxt "wizard.url.networkPacing.summary"
msgid "Waits: {{requests}} between checks, {{downloads}} before media starts, {{subtitles}} before subtitle files. Connections: {{fragments}}."
msgstr "Паузи: {{requests}} між перевірками, {{downloads}} перед початком медіа, {{subtitles}} перед файлами субтитрів. З'єднання: {{fragments}}."

msgctxt "wizard.url.networkPacing.tooltip"
msgid "These waits happen inside each download. Arroxy still keeps normal queued downloads one-at-a-time."
msgstr "Паузи відбуваються всередині кожного завантаження. Arroxy як і раніше обробляє чергові завантаження по одному."

msgctxt "wizard.url.networkPacing.tooltips.balanced"
msgid "Default. Adds short pauses and uses one download connection."
msgstr "За замовчуванням. Додає короткі паузи та використовує одне з'єднання для завантаження."

msgctxt "wizard.url.networkPacing.tooltips.careful"
msgid "Adds longer pauses for large playlists or networks that frequently hit limits."
msgstr "Додає довші паузи для великих плейлистів або мереж, які часто упираються в ліміти."

msgctxt "wizard.url.networkPacing.tooltips.custom"
msgid "Tune the advanced per-download controls yourself."
msgstr "Налаштуйте розширені параметри кожного завантаження самостійно."

msgctxt "wizard.url.networkPacing.tooltips.off"
msgid "Uses only the small baseline pauses Arroxy keeps for media and subtitles."
msgstr "Використовує лише невеликі базові паузи Arroxy для медіа та субтитрів."

msgctxt "wizard.url.networkPacing.units.seconds"
msgid "sec"
msgstr "сек"

msgctxt "wizard.url.networkPacing.units.threads"
msgid "threads"
msgstr "потоків"

msgctxt "wizard.url.placeholder"
msgid "https://..."
msgstr "https://www.youtube.com/watch?v=..."

msgctxt "wizard.url.playlistProbeLimit.current"
msgid "Current limit: {{count}} items"
msgstr "Поточний ліміт: {{count}} елементів"

msgctxt "wizard.url.playlistProbeLimit.custom"
msgid "Custom…"
msgstr "Власне…"

msgctxt "wizard.url.playlistProbeLimit.customDialogCancel"
msgid "Cancel"
msgstr "Скасувати"

msgctxt "wizard.url.playlistProbeLimit.customDialogDescription"
msgid "Use a whole number from {{min}} to {{max}}."
msgstr "Введи ціле число від {{min}} до {{max}}."

msgctxt "wizard.url.playlistProbeLimit.customDialogSave"
msgid "Save limit"
msgstr "Зберегти ліміт"

msgctxt "wizard.url.playlistProbeLimit.customDialogTitle"
msgid "Custom playlist scan limit"
msgstr "Власний ліміт сканування плейлиста"

msgctxt "wizard.url.playlistProbeLimit.customValue"
msgid "Custom: {{count}} items"
msgstr "Власне: {{count}} елементів"

msgctxt "wizard.url.playlistProbeLimit.description"
msgid "Maximum entries Arroxy loads when a playlist, channel, or search result is opened."
msgstr "Максимальна кількість записів, які Arroxy завантажує під час відкриття плейлиста, каналу або результатів пошуку."

msgctxt "wizard.url.playlistProbeLimit.invalid"
msgid "Use a whole number from 1 to 5000"
msgstr "Введи ціле число від 1 до 5000"

msgctxt "wizard.url.playlistProbeLimit.label"
msgid "Playlist items to scan"
msgstr "Елементів плейлиста для сканування"

msgctxt "wizard.url.playlistProbeLimit.option"
msgid "{{count}} items"
msgstr "{{count}} елементів"

msgctxt "wizard.url.playlistProbeLimit.tooltip"
msgid "Maps to yt-dlp --playlist-end: Arroxy only asks for this many playlist, channel, or search entries while building the picker."
msgstr "Відповідає параметру yt-dlp --playlist-end: Arroxy запитує лише таку кількість записів плейлиста, каналу або пошуку під час побудови вибірки."

