msgctxt "repair.hints.blockedOrQuarantined"
msgid "Windows blocked the file (SmartScreen / Defender). Pick an installed copy or whitelist the runtime folder."
msgstr "Windows ilizuia faili (SmartScreen / Defender). Chagua nakala iliyosakinishwa au weka saraka ya runtime kwenye orodha nyeupe."

msgctxt "repair.hints.downloadFailed"
msgid "Download failed. Check your internet connection and retry."
msgstr "Upakuaji umeshindwa. Angalia muunganisho wako wa intaneti na ujaribu tena."

msgctxt "repair.hints.extractFailed"
msgid "Archive extraction failed. The download may be corrupt — retry."
msgstr "Ufunguzi wa kumbukumbu umeshindwa. Upakuaji unaweza kuwa umeharibiwa — jaribu tena."

msgctxt "repair.hints.hashFailed"
msgid "Checksum mismatch on the downloaded file. Retry the download."
msgstr "Checksum ya faili iliyopakuliwa haifanani. Pakua upya faili."

msgctxt "repair.hints.pairIncomplete"
msgid "ffmpeg and ffprobe must both be set as a matched pair."
msgstr "ffmpeg na ffprobe lazima ziwekwe zote kwa pamoja kama jozi inayolingana."

msgctxt "repair.hints.permissionDenied"
msgid "The system refused to run the file. Pick a copy you trust or retry as admin."
msgstr "Mfumo ulikataa kuendesha faili. Chagua nakala unayoiamini au jaribu tena kama msimamizi."

msgctxt "repair.hints.spawnFailed"
msgid "The file is missing or could not be launched. Pick a working copy."
msgstr "Faili haipo au haiwezi kuzinduliwa. Chagua nakala inayofanya kazi."

msgctxt "repair.hints.timeout"
msgid "The version probe timed out. The file may be hung — retry."
msgstr "Uchunguzi wa toleo ulichukua muda mrefu. Faili inaweza kuwa imesimama — jaribu tena."

