msgctxt "wizard.url.playlistProbeLimit.description"
msgid "Maximum entries Arroxy loads when a playlist, channel, or search result is opened."
msgstr "Idadi ya juu ya maingizo ambayo Arroxy hupakia wakati playlist, kituo, au matokeo ya utafutaji yanafunguliwa."

msgctxt "wizard.url.playlistProbeLimit.invalid"
msgid "Use a whole number from 1 to 5000"
msgstr "Tumia nambari nzima kutoka 1 hadi 5000"

msgctxt "wizard.url.playlistProbeLimit.label"
msgid "Playlist items to scan"
msgstr "Vipande vya playlist vya kuskanisha"

msgctxt "wizard.url.playlistProbeLimit.option"
msgid "{{count}} items"
msgstr "Vipande {{count}}"

msgctxt "wizard.url.playlistProbeLimit.tooltip"
msgid "Maps to yt-dlp --playlist-end: Arroxy only asks for this many playlist, channel, or search entries while building the picker."
msgstr "Inalingana na yt-dlp --playlist-end: Arroxy inauliza idadi hii tu ya maingizo ya playlist, kituo, au utafutaji wakati wa kujenga kichaguzi."

msgctxt "wizard.url.profile.activeLabel"
msgid "Active profile"
msgstr "Wasifu unaotumika"

msgctxt "wizard.url.profile.changeGlobalDestination"
msgid "Change global destination"
msgstr "Badilisha mahali pa kuhifadhi kwa jumla"

msgctxt "wizard.url.profile.destinationFallback"
msgid "Destination"
msgstr "Mahali pa kuhifadhi"

msgctxt "wizard.url.profile.editActive"
msgid "Edit active profile"
msgstr "Hariri wasifu unaotumika"

msgctxt "wizard.url.profile.manageProfiles"
msgid "Manage profiles"
msgstr "Dhibiti wasifu"

msgctxt "wizard.url.profile.menuDescription"
msgid "Change the active profile for Quick Download, Bulk URLs, and playlists."
msgstr "Badilisha wasifu unaotumika kwa Quick Download, URL nyingi na orodha za kucheza."

msgctxt "wizard.url.profile.menuTitle"
msgid "Switch profile"
msgstr "Badilisha wasifu"

msgctxt "wizard.url.profile.newProfile"
msgid "New profile"
msgstr "Wasifu mpya"

msgctxt "wizard.url.profile.switchAria"
msgid "Switch download profile: {{profileName}}"
msgstr "Badilisha wasifu wa kupakua: {{profileName}}"

msgctxt "wizard.url.profile.switchTitle"
msgid "Switch download profile"
msgstr "Badilisha wasifu wa kupakua"

msgctxt "wizard.url.proxy.clear"
msgid "Clear"
msgstr "Futa"

msgctxt "wizard.url.proxy.description"
msgid "Route traffic through a proxy — useful for geo-restricted content."
msgstr "Peleka trafiki kupitia proksi — muhimu kwa maudhui yenye vizuizi vya kijiografia."

msgctxt "wizard.url.proxy.label"
msgid "Proxy URL"
msgstr "Proxy URL"

msgctxt "wizard.url.proxy.placeholder"
msgid "http://host:port"
msgstr "http://host:port"

msgctxt "wizard.url.quickBulkAllFailed"
msgid "None of those URLs could be prepared"
msgstr "Hakuna URL kati ya hizi iliyoweza kuandaliwa"

msgctxt "wizard.url.quickDownload"
msgid "Quick Download"
msgstr "Upakuaji wa haraka"

msgctxt "wizard.url.quickDownloadTooltip"
msgid "Will download using: {{profileName}}"
msgstr "Itapakua kwa kutumia: {{profileName}}"

msgctxt "wizard.url.quickFailed"
msgid "Couldn't add this one: {{error}}"
msgstr "Haikuweza kuongeza hii: {{error}}"

msgctxt "wizard.url.quickPartialFailed_one"
msgid "Queued what worked. {{count}} URL could not be prepared."
msgstr "Kilichofanya kazi kimeongezwa kwenye foleni. URL {{count}} haikuweza kuandaliwa."

msgctxt "wizard.url.quickPartialFailed_other"
msgid "Queued what worked. {{count}} URLs could not be prepared."
msgstr "Vilivyofanya kazi vimeongezwa kwenye foleni. URL {{count}} hazikuweza kuandaliwa."

msgctxt "wizard.url.quickPrepareFailed"
msgid "Queue item could not be prepared"
msgstr "Kipengee cha foleni hakikuweza kuandaliwa"

msgctxt "wizard.url.quickPreparing"
msgid "Preparing"
msgstr "Inaandaa"

msgctxt "wizard.url.quickProbeFailed"
msgid "Probe failed"
msgstr "Uchunguzi umeshindikana"

msgctxt "wizard.url.quickQueued"
msgid "Added to queue"
msgstr "Imeongezwa kwenye foleni"

msgctxt "wizard.url.quickSingleOnly"
msgid "Paste a video, playlist, channel, or search URL to get started."
msgstr "Bandika URL ya video, orodha ya kucheza, kituo au utafutaji ili kuanza."

msgctxt "wizard.url.singleFilenameId.toggle"
msgid "Add video ID to single filenames"
msgstr "Ongeza ID ya video kwenye majina ya faili moja moja"

msgctxt "wizard.url.singleFilenameId.toggleDescription"
msgid "Keeps one-off downloads unique when titles change or collide."
msgstr "Huweka upakuaji wa mara moja kuwa wa kipekee wakati vichwa vinabadilika au kugongana."
