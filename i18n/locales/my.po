msgctxt "wizard.url.quickSingleOnly"
msgid "Paste a video, playlist, channel, or search URL to get started."
msgstr "စတင်ရန် ဗီဒီယို၊ playlist၊ channel သို့မဟုတ် search URL ကို paste လုပ်ပါ။"

msgctxt "wizard.url.singleFilenameId.toggle"
msgid "Add video ID to single filenames"
msgstr "တစ်ခုချင်း ဖိုင်အမည်များတွင် ဗီဒီယို ID ထည့်ရန်"

msgctxt "wizard.url.singleFilenameId.toggleDescription"
msgid "Keeps one-off downloads unique when titles change or collide."
msgstr "ခေါင်းစဉ်များ ပြောင်းလဲခြင်း သို့မဟုတ် တူညီခြင်း ဖြစ်သည့်အခါ တစ်ခုချင်း ဒေါင်းလုဒ်များကို မတူညီအောင် ထိန်းထားသည်။"

msgctxt "wizard.url.tabs.profiles"
msgid "Profiles"
msgstr "ပရိုဖိုင်များ"

msgctxt "wizard.url.tabs.settings"
msgid "Settings"
msgstr "ဆက်တင်များ"

msgctxt "player.back"
msgid "Back to library"
msgstr "စာကြည့်တိုက်သို့ ပြန်သွားရန်"

msgctxt "player.noMedia"
msgid "Media not found"
msgstr "မီဒီယာ ရှာမတွေ့ပါ"

msgctxt "player.noAsset"
msgid "No playable file found"
msgstr "ဖွင့်နိုင်သော ဖိုင် ရှာမတွေ့ပါ"

msgctxt "player.subtitles"
msgid "Subtitles"
msgstr "စာတန်းထိုးများ"

msgctxt "player.speed"
msgid "Speed"
msgstr "အမြန်နှုန်း"

